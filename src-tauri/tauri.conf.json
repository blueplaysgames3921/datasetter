{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Datasetter",
  "version": "0.1.0",
  "identifier": "com.blueplaysgames3921.datasetter",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd src-ui && npm run dev",
    "beforeBuildCommand": "cd src-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Datasetter",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' http://127.0.0.1:* https://api.anthropic.com https://*.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar/*": "sidecar/"
    },
    "externalBin": [
      "sidecar/main"
    ]
  },
  "plugins": {
    "notification": {
      "windows": {
        "sound": "Default"
      }
    },
    "dialog": {},
    "fs": {
      "all": true,
      "scope": [
        "$HOME/datasetter/**",
        "$TEMP/**"
      ]
    },
    "shell": {
      "open": true
    }
  }
}